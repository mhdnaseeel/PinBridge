{
  "manifest_version": 3,
  "name": "PinBridge",
  "version": "1.1",
  "description": "OTP‑Mirror – Get OTPs from your Android phone on your Mac.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "PinBridge",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "permissions": [
    "storage",
    "notifications",
    "sidePanel",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://*.firebaseio.com/*",
    "https://*.firebaseapp.com/*",
    "https://*.cloudfunctions.net/*",
    "https://*.web.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
