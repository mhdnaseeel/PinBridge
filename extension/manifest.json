{
  "manifest_version": 3,
  "name": "PinBridge",
  "version": "1.0",
  "description": "OTP‑Mirror – Get OTPs from your Android phone on your Mac.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.firebaseio.com/*",
    "https://*.firebaseapp.com/*",
    "https://*.cloudfunctions.net/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ]
}
