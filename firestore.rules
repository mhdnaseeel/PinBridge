rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /pairings/{deviceId} {
      // Allow any authenticated user to create a new pairing session
      allow create: if request.auth != null;
      // Read/update if the caller's UID matches the document's googleUid,
      // OR if the document has no googleUid set yet,
      // OR if the document is NOT yet paired (allows the mobile app to check-in).
      allow read, update: if request.auth != null 
        && (resource.data.googleUid == request.auth.uid 
            || !resource.data.keys().hasAny(['googleUid'])
            || resource.data.paired != true);
      allow delete: if request.auth != null 
        && (resource.data.googleUid == request.auth.uid 
            || !resource.data.keys().hasAny(['googleUid']));
    }
    match /otps/{deviceId} {
      // OTP docs contain AES-256-GCM encrypted ciphertext only — no plaintext secrets.
      // Write: any authenticated user (the Android app writes from its anonymous UID)
      allow write: if request.auth != null;
      // Read: only the uploader can read, OR the owner of the pairing (from pairings doc), OR legacy docs without uploaderUid field (V-13)
      allow read: if request.auth != null
        && (resource.data.uploaderUid == request.auth.uid
            || get(/databases/$(database)/documents/pairings/$(deviceId)).data.googleUid == request.auth.uid
            || !resource.data.keys().hasAny(['uploaderUid']));
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
