rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pairing and OTP documents - Secured by application-level AES encryption
    // Logic: Both sides login anonymously. The deviceId is the document key.
    // Pairing collection
    match /pairings/{deviceId} {
      allow create: if request.auth != null && 
                    request.resource.data.keys().hasAll(['secret', 'pairingCode']) &&
                    request.resource.data.secret is string && request.resource.data.secret.size() == 44 &&
                    request.resource.data.pairingCode is string && request.resource.data.pairingCode.matches('^[0-9]{6}$');
      allow read, update, delete: if request.auth != null;
    }

    match /otps/{deviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                    request.resource.data.keys().hasAll(['otp', 'iv', 'sender', 'ts', 'expiresAt']);
    }
  }
}
