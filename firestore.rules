rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /pairings/{deviceId} {
      // Allow any authenticated user to create a new pairing session
      allow create: if request.auth != null;
      // Security (M-1): Read/update requires ownership OR no owner set yet.
      // The old `resource.data.paired != true` clause was removed because it
      // allowed ANY authenticated user to read/update any unpaired document,
      // enabling enumeration of active pairing sessions.
      // The heartbeat-field-only update clause is retained for the socket server.
      allow read, update: if request.auth != null 
        && (resource.data.googleUid == request.auth.uid 
            || !resource.data.keys().hasAny(['googleUid'])
            || (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['googleUid', 'secret', 'paired'])));
      allow delete: if request.auth != null 
        && (resource.data.googleUid == request.auth.uid 
            || !resource.data.keys().hasAny(['googleUid']));
    }
    match /otps/{deviceId} {
      // OTP docs contain AES-256-GCM encrypted ciphertext only — no plaintext secrets.
      // Write: any authenticated user (the Android app writes from its anonymous UID)
      allow write: if request.auth != null;
      // Security (M-2): Read: only the uploader or the pairing owner.
      // Legacy fallback for docs without uploaderUid has been removed.
      // If old docs exist without uploaderUid, backfill them or delete them.
      allow read: if request.auth != null
        && (resource.data.uploaderUid == request.auth.uid
            || get(/databases/$(database)/documents/pairings/$(deviceId)).data.googleUid == request.auth.uid);
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
